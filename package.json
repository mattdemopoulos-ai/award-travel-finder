import { useState } from "react";

export default function Home() {
  const [message, setMessage] = useState("Button has not been clicked yet.");

  function handleClick() {
    setMessage("Find Awards button works.");
  }

  return (
    <div style={{ padding: "40px", fontFamily: "Arial, sans-serif" }}>
      <h1>Award Travel Finder ✈️</h1>
      <p>{message}</p>

      <button
        onClick={handleClick}
        style={{
          padding: "12px 18px",
          backgroundColor: "black",
          color: "white",
          border: "none",
          borderRadius: "8px",
          cursor: "pointer"
        }}
      >
        Find Awards
      </button>
    </div>
  );
}
