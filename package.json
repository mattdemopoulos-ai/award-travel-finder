import React, { useState } from "react";

const allResults = [
  {
    tag: "Best Overall",
    program: "Iberia Avios",
    origin: "BOG",
    destination: "MAD",
    route: "BOG → MAD",
    cabin: "Business",
    passengers: 1,
    miles: 42500,
    taxes: 120,
    cpp: 4.9,
    notes: "Excellent nonstop sweet spot"
  },
  {
    tag: "Best Value",
    program: "Flying Blue",
    origin: "BOG",
    destination: "CDG",
    route: "BOG → CDG",
    cabin: "Business",
    passengers: 1,
    miles: 55000,
    taxes: 210,
    cpp: 4.2,
    notes: "Good availability and transfer options"
  },
  {
    tag: "Lowest Fees",
    program: "LifeMiles",
    origin: "MDE",
    destination: "MAD",
    route: "MDE → MAD",
    cabin: "Business",
    passengers: 1,
    miles: 63000,
    taxes: 78,
    cpp: 3.8,
    notes: "Lower fees, one-stop option"
  },
  {
    tag: "Popular",
    program: "Flying Blue",
    origin: "MDE",
    destination: "AMS",
    route: "MDE → AMS",
    cabin: "Business",
    passengers: 1,
    miles: 59000,
    taxes: 195,
    cpp: 4.1,
    notes: "Strong Europe option from Medellín"
  },
  {
    tag: "Popular",
    program: "Iberia Avios",
    origin: "MDE",
    destination: "MAD",
    route: "MDE → MAD",
    cabin: "Economy",
    passengers: 1,
    miles: 25500,
    taxes: 95,
    cpp: 2.7,
    notes: "Economy fallback option"
  }
];

export default function Home() {
  const [origin, setOrigin] = useState("");
  const [destination, setDestination] = useState("");
  const [cabin, setCabin] = useState("Business");
  const [results, setResults] = useState(allResults);

  function handleSearch() {
    const filtered = allResults.filter((result) => {
      const matchesOrigin =
        origin === "" || result.origin === origin.toUpperCase();

      const matchesDestination =
        destination === "" || result.destination === destination.toUpperCase();

      const matchesCabin = result.cabin === cabin;

      return matchesOrigin && matchesDestination && matchesCabin;
    });

    setResults(filtered);
  }

  function handleReset() {
    setOrigin("");
    setDestination("");
    setCabin("Business");
    setResults(allResults);
  }

  return (
    <div style={pageStyle}>
      <div style={containerStyle}>
        <h1 style={titleStyle}>Award Travel Finder ✈️</h1>
        <p style={subtitleStyle}>
          Find the best way to fly using points
        </p>

        <div style={searchBoxStyle}>
          <h2 style={{ marginTop: 0 }}>Search awards</h2>

          <div style={gridStyle}>
            <input
              style={inputStyle}
              placeholder="Origin (e.g. MDE)"
              value={origin}
              onChange={(e) => setOrigin(e.target.value.toUpperCase())}
            />

            <input
              style={inputStyle}
              placeholder="Destination (e.g. MAD)"
              value={destination}
              onChange={(e) => setDestination(e.target.value.toUpperCase())}
            />

            <select
              style={inputStyle}
              value={cabin}
              onChange={(e) => setCabin(e.target.value)}
            >
              <option>Business</option>
              <option>Economy</option>
              <option>First</option>
            </select>
          </div>

          <div style={{ marginTop: "16px", display: "flex", gap: "12px" }}>
            <button style={buttonStyle} onClick={handleSearch}>
              Find Awards
            </button>

            <button style={secondaryButtonStyle} onClick={handleReset}>
              Reset
            </button>
          </div>
        </div>

        <h2>Results</h2>
        <p style={{ color: "#666" }}>
          {results.length} result{results.length === 1 ? "" : "s"}
        </p>

        {results.length === 0 ? (
          <div style={cardStyle}>
            <h3 style={{ marginTop: 0 }}>No results found</h3>
            <p style={{ marginBottom: 0 }}>
              Try MDE → MAD, BOG → MAD, BOG → CDG, or MDE → AMS.
            </p>
          </div>
        ) : (
          <div style={resultsGridStyle}>
            {results.map((r, i) => (
              <div key={i} style={cardStyle}>
                <div style={tagStyle}>{r.tag}</div>
                <h3 style={{ marginBottom: "8px" }}>{r.program}</h3>
                <p style={{ color: "#666" }}>{r.route}</p>
                <p><strong>{r.miles.toLocaleString()}</strong> miles</p>
                <p><strong>${r.taxes}</strong> taxes</p>
                <p><strong>{r.cpp}</strong> cpp</p>
                <p><strong>{r.cabin}</strong></p>
                <p style={{ marginBottom: 0 }}>{r.notes}</p>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}

const pageStyle = {
  fontFamily: "Arial, sans-serif",
  background: "#f7f7f7",
  minHeight: "100vh",
  padding: "40px 20px"
};

const containerStyle = {
  maxWidth: "1100px",
  margin: "0 auto"
};

const titleStyle = {
  fontSize: "48px",
  marginBottom: "12px"
};

const subtitleStyle = {
  fontSize: "20px",
  color: "#555",
  marginTop: 0
};

const searchBoxStyle = {
  background: "white",
  borderRadius: "16px",
  padding: "24px",
  boxShadow: "0 8px 24px rgba(0,0,0,0.08)",
  marginBottom: "32px"
};

const gridStyle = {
  display: "grid",
  gridTemplateColumns: "repeat(auto-fit, minmax(220px, 1fr))",
  gap: "12px"
};

const resultsGridStyle = {
  display: "grid",
  gridTemplateColumns: "repeat(auto-fit, minmax(280px, 1fr))",
  gap: "18px"
};

const inputStyle = {
  padding: "14px 16px",
  borderRadius: "10px",
  border: "1px solid #ddd",
  fontSize: "16px",
  width: "100%",
  boxSizing: "border-box"
};

const buttonStyle = {
  background: "#111",
  color: "white",
  border: "none",
  borderRadius: "10px",
  padding: "14px 20px",
  fontSize: "16px",
  cursor: "pointer"
};

const secondaryButtonStyle = {
  background: "white",
  color: "#111",
  border: "1px solid #ddd",
  borderRadius: "10px",
  padding: "14px 20px",
  fontSize: "16px",
  cursor: "pointer"
};

const cardStyle = {
  background: "white",
  borderRadius: "16px",
  padding: "22px",
  boxShadow: "0 8px 24px rgba(0,0,0,0.08)"
};

const tagStyle = {
  display: "inline-block",
  background: "#111",
  color: "white",
  borderRadius: "999px",
  padding: "6px 12px",
  fontSize: "12px",
  marginBottom: "14px"
};
